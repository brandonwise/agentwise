      ]
    },
    "sentimentscope": {
      "command": "C:\\Users\\Riva\\AppData\\Local\\Microsoft\\WindowsApps\\PythonSoftwareFoundation.Python.3.13_qbz5n2kfra8p0\\python.exe",
      "args": [
        "C:\\Users\\Riva\\Desktop\\sentimentscope-mcp\\mcp_server.py"
      ]
    },
    "google-drive": {
      "command": "npx",
      "args": [
