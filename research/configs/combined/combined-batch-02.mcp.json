        "@modelcontextprotocol/server-memory"
      ]
    },
    "runZero MCP": {
      "command": "/Users/tyler/.local/share/virtualenvs/runZero-scripts-VoSeJ_A1/bin/python3",
      "args": [
        "/Users/tyler/git/runZero-scripts/mcp/run.py"
      ],
      "enabled": true
    },
    "TahubuSF": {
      "command": "uv",
      "args": [
        "--directory",
        "D:\\repos\\TahubuSF",
        "run",
        "run.py"
      ]
