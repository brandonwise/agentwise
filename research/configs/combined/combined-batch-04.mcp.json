{
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "env": {},
      "usagePolicy": {
        "priority": "medium",
        "prompt": "Use fetch for retrieving online content or API data. Ensure requests are secure and respect rate limits. Cache results when appropriate to reduce redundant calls.",
        "useCases": [
          "data retrieval",
          "API interaction"
        ],
        "constraints": "Respect API rate limits and terms. Secure sensitive data in requests."
      }
    },
    "github-mcp-server": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "your_github_personal_access_token_here"
      },
      "usagePolicy": {
        "priority": "high",
        "prompt": "Use for all GitHub interactions including repository management, issue tracking, and pull requests. Ensure token security and confirm user intent for repository modifications.",
        "useCases": [
          "repository management",
          "issue tracking",
          "collaboration"
        ],
        "constraints": "Protect personal access token. Confirm destructive actions with user."
      }
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "your_brave_api_key_here"
      },
      "usagePolicy": {
        "priority": "medium",
        "prompt": "Use brave-search for web and local searches to gather information or answer user queries. Prioritize for factual data or recent information. Use domain filters to refine results when applicable.",
        "useCases": [
          "information gathering",
          "research",
          "local business search"
        ],
        "constraints": "Secure API key. Use sparingly for non-critical queries to manage API usage."
      },
      "recommendation": "Added to enhance search capabilities with a focus on privacy-preserving search results. Complements fetch by offering structured search data."
    },
