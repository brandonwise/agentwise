direction: right

title: {
  label: agentwise — How it works
  style: {
    font-size: 28
    bold: true
    font-color: "#1a1a2e"
  }
}

input: {
  label: "MCP Configs"
  shape: document
  style: {
    fill: "#74b9ff"
    font-color: "#fff"
    font-size: 18
    bold: true
  }
}

engine: {
  label: "Core Engine"
  style: {
    fill: "#ffeaa7"
    stroke: "#f39c12"
    border-radius: 10
    font-size: 16
  }

  parse: {
    label: "Parse"
    style: { fill: "#fdcb6e"; font-size: 16 }
  }

  rules: {
    label: "12 Rules"
    style: { fill: "#f39c12"; font-color: "#fff"; font-size: 16; bold: true }
  }

  score: {
    label: "Score 0-100"
    style: { fill: "#fdcb6e"; font-size: 16 }
  }

  parse -> rules -> score
}

enrich: {
  label: "Enrichment (optional)"
  style: {
    fill: "#dfe6e9"
    stroke: "#636e72"
    stroke-dash: 3
    border-radius: 10
    font-size: 14
  }

  osv: {
    label: "OSV\nLive CVEs"
    shape: cloud
    style: { fill: "#6c5ce7"; font-color: "#fff"; font-size: 14 }
  }

  epss: {
    label: "EPSS\nExploit Prob"
    shape: cloud
    style: { fill: "#a29bfe"; font-color: "#fff"; font-size: 14 }
  }

  npm: {
    label: "npm\nSupply Chain"
    shape: cloud
    style: { fill: "#0984e3"; font-color: "#fff"; font-size: 14 }
  }

  deps: {
    label: "deps.dev\nDep Graph"
    shape: cloud
    style: { fill: "#00b894"; font-color: "#fff"; font-size: 14 }
  }
}

output: {
  label: "Output"
  style: {
    fill: "#2d3436"
    border-radius: 10
    font-color: "#fff"
    font-size: 16
  }

  term: {
    label: "Terminal"
    style: { fill: "#00cec9"; font-color: "#fff"; font-size: 15 }
  }
  json: {
    label: "JSON"
    style: { fill: "#636e72"; font-color: "#fff"; font-size: 15 }
  }
  sarif: {
    label: "SARIF"
    style: { fill: "#636e72"; font-color: "#fff"; font-size: 15 }
  }
}

input -> engine.parse: {
  style.stroke-width: 2
}

engine.rules -> enrich.osv: "--live" {
  style.stroke-dash: 3
  style.stroke: "#6c5ce7"
}
engine.rules -> enrich.epss: "--live" {
  style.stroke-dash: 3
  style.stroke: "#a29bfe"
}
engine.rules -> enrich.npm: "--supply-chain" {
  style.stroke-dash: 3
  style.stroke: "#0984e3"
}
engine.rules -> enrich.deps: "--supply-chain" {
  style.stroke-dash: 3
  style.stroke: "#00b894"
}

engine.score -> output.term
engine.score -> output.json
engine.score -> output.sarif
